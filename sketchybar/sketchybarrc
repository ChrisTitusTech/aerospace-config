#!/bin/bash

source "$CONFIG_DIR/colors.sh"

# === BAR CONFIGURATION ===
sketchybar --bar                     \
  position=top                       \
  height=34                          \
  y_offset=0                         \
  color=$BG0                         \
  border_color=$BG2                  \
  border_width=0                     \
  padding_left=10                    \
  padding_right=10                   \
  shadow=off                         \
  sticky=on                          \
  topmost=screen                     \
  blur_radius=0

# === DEFAULT ITEM CONFIGURATION ===
sketchybar --default                 \
  updates=when_shown                 \
  background.color=$BG1              \
  background.corner_radius=6         \
  background.height=26               \
  icon.font="JetBrainsMono Nerd Font:Bold:13"  \
  icon.color=$WHITE                  \
  label.font="JetBrainsMono Nerd Font:Regular:13"  \
  label.color=$WHITE                 \
  padding_left=6                     \
  padding_right=6

# === LEFT SIDE ===

# Workspaces
for i in {1..8}; do
  sketchybar --add space space.$i left   \
    --set space.$i                       \
      space=$i                           \
      ignore_association=on              \
      label="$i"                         \
      label.font="JetBrainsMono Nerd Font:Bold:12" \
      label.padding_left=8               \
      label.padding_right=8              \
      background.drawing=on              \
      background.color=$BG2              \
      background.corner_radius=3         \
      background.height=20               \
      background.border_width=0          \
      icon.drawing=off                   \
      click_script="aerospace workspace $i"
done

# Front App
sketchybar --add item front_app left       \
  --set front_app                          \
    background.color=$BG0                  \
    label.font="JetBrainsMono Nerd Font:Bold:13" \
    script="$CONFIG_DIR/plugins/front_app.sh"    \
  --subscribe front_app front_app_switched

# === RIGHT SIDE ===

# WiFi
sketchybar --add item wifi right           \
  --set wifi                               \
    background.color=$BG0                  \
    icon.font="SF Pro:Semibold:14.0"      \
    label.font="JetBrainsMono Nerd Font:Regular:12" \
    icon=""                                \
    icon.color=$BLUE                       \
    click_script="$CONFIG_DIR/plugins/wifi_click.sh" \
    script="$CONFIG_DIR/plugins/wifi.sh"  \
  --subscribe wifi wifi_change system_woke

# Battery
sketchybar --add item battery right        \
  --set battery                            \
    background.color=$BG0                  \
    icon.font="SF Pro:Semibold:14.0"      \
    label.font="JetBrainsMono Nerd Font:Regular:12" \
    script="$CONFIG_DIR/plugins/battery.sh" \
  --subscribe battery power_source_change system_woke

# Calendar
sketchybar --add item calendar right       \
  --set calendar                           \
    background.color=$BG0                  \
    label.font="JetBrainsMono Nerd Font:Regular:12" \
    update_freq=60                         \
    icon.drawing=off                       \
    script="$CONFIG_DIR/plugins/calendar.sh" \
  --subscribe calendar system_woke

# Initialize active workspace highlighting immediately on bar startup.
"$CONFIG_DIR/plugins/aerospace_workspace.sh"

# === REFRESH ===
sketchybar --update
